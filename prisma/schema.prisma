  @@schema("public")
}

// =============================================================================
// §5 — BILLING & SUBSCRIPTIONS
// =============================================================================

model billing_plan_catalog {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  segment               org_type
  plan_code             String                  // free | pro | elite
  display_name          String
  plan_tier             Int                     // 0=free, 1=pro, 2=elite
  monthly_price_usd     Int                     @default(0)
  annual_price_usd      Int                     @default(0)
  success_fee_pct       String?                 // stored as rate schedule JSON string
  platform_fee_pct      String?                 // stored as rate schedule JSON string
  is_default            Boolean                 @default(false)
  is_active             Boolean                 @default(true)
  is_public             Boolean                 @default(true)
  metadata              Json                    @default("{}")
  created_at            DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at            DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  billing_plan_features billing_plan_features[]
  billing_plan_prices   billing_plan_prices[]
  org_subscriptions     org_subscriptions[]
  plan_capabilities     plan_capabilities[]

  @@unique([segment, plan_code], map: "billing_plan_catalog_segment_code_key")
  @@unique([segment, plan_tier], map: "billing_plan_catalog_segment_tier_key")
  @@index([segment, is_active, is_public, plan_tier], map: "billing_plan_catalog_active_public_idx")
  @@schema("public")
}

model billing_plan_features {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plan_id              String               @db.Uuid
  feature_key          String
  feature_label        String
  feature_value_text   String?
  limit_value          Int?
  is_unlimited         Boolean              @default(false)
  sort_order           Int                  @default(0)
  metadata             Json                 @default("{}")
  created_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  billing_plan_catalog billing_plan_catalog @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([plan_id, feature_key], map: "billing_plan_features_plan_feature_key")
  @@index([plan_id, sort_order, feature_key], map: "billing_plan_features_plan_sort_idx")
  @@schema("public")
}

model billing_plan_prices {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  plan_id              String               @db.Uuid
  billing_interval     billing_interval
  amount_cents         Int
  currency             String               @default("USD")
  stripe_price_id      String?
  created_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  billing_plan_catalog billing_plan_catalog @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([plan_id, billing_interval], map: "billing_plan_prices_plan_interval_key")
  @@index([billing_interval, amount_cents], map: "billing_plan_prices_interval_amount_idx")
  @@schema("public")
}

model billing_webhook_events {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     String   @default("stripe")
  event_id     String
  event_type   String
  livemode     Boolean  @default(false)
  payload      Json     @default("{}")
  processed_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  @@unique([provider, event_id])
  @@index([provider, processed_at(sort: Desc)], map: "billing_webhook_events_provider_processed_idx")
  @@schema("public")
}

model capabilities {
  code                       String                       @id
  description                String
  category                   String
  created_at                 DateTime                     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  org_capabilities_overrides org_capabilities_overrides[]
  plan_capabilities          plan_capabilities[]

  @@unique([category, code], map: "capabilities_category_code_idx")
  @@schema("public")
}

model plan_capabilities {
  plan_id              String               @db.Uuid
  capability_code      String
  is_enabled           Boolean              @default(true)
  created_at           DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  capabilities         capabilities         @relation(fields: [capability_code], references: [code], onDelete: Cascade, onUpdate: NoAction)
  billing_plan_catalog billing_plan_catalog @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([plan_id, capability_code])
  @@index([capability_code, plan_id], map: "plan_capabilities_capability_idx")
  @@schema("public")
}

model org_capabilities_overrides {
  org_id          String        @db.Uuid
  capability_code String
  is_enabled      Boolean
  source          String        @default("manual")
  expires_at      DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  capabilities    capabilities  @relation(fields: [capability_code], references: [code], onDelete: Cascade, onUpdate: NoAction)
  organizations   organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([org_id, capability_code])
  @@index([capability_code, org_id], map: "org_capabilities_overrides_capability_idx")
  @@index([org_id, expires_at], map: "org_capabilities_overrides_org_idx")
  @@schema("public")
}

model org_feature_usage_counters {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String        @db.Uuid
  feature_key   String        // connect_requests_sent | warm_intros_sent | data_room_views | etc.
  period_start  DateTime      @db.Date
  period_end    DateTime      @db.Date
  usage_count   BigInt        @default(0)
  metadata      Json          @default("{}")
  created_at    DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([org_id, feature_key, period_start, period_end], map: "org_feature_usage_unique_period")
  @@index([org_id, period_start(sort: Desc), period_end(sort: Desc)], map: "org_feature_usage_org_period_idx")
  @@schema("public")
}

model org_subscription_accounts {
  org_id                String        @id @db.Uuid
  billing_email         String?
  provider_customer_ref String?       // Stripe customer ID
  metadata              Json          @default("{}")
  created_at            DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at            DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations         organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

model org_subscriptions {
  id                        String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id                    String                      @db.Uuid
  plan_id                   String                      @db.Uuid
  status                    billing_subscription_status @default(active)
  billing_interval          billing_interval            @default(monthly)
  started_at                DateTime                    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  current_period_start      DateTime?                   @db.Timestamptz(6)
  current_period_end        DateTime?                   @db.Timestamptz(6)
  cancel_at_period_end      Boolean                     @default(false)
  canceled_at               DateTime?                   @db.Timestamptz(6)
  source                    String                      @default("manual")
  external_subscription_ref String?                     // Stripe subscription ID
  trial_ends_at             DateTime?                   @db.Timestamptz(6)
  metadata                  Json                        @default("{}")
  created_at                DateTime                    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                DateTime                    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations             organizations               @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  billing_plan_catalog      billing_plan_catalog        @relation(fields: [plan_id], references: [id], onUpdate: NoAction)

  @@unique([org_id], map: "org_subscriptions_single_active_idx", where: raw("(status = ANY (ARRAY['trialing'::billing_subscription_status, 'active'::billing_subscription_status, 'past_due'::billing_subscription_status, 'paused'::billing_subscription_status]))"))
  @@index([org_id, created_at(sort: Desc)], map: "org_subscriptions_org_created_idx")
  @@index([plan_id, status, current_period_end(sort: Desc)], map: "org_subscriptions_plan_status_idx")
  @@schema("public")
}

// =============================================================================
// §6 — DISCOVERY & AI MATCHING
// =============================================================================

/// Who viewed whose profile and when (for analytics and interest signals).
model discovery_profile_views {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  viewer_org_id   String        @db.Uuid
  target_org_id   String        @db.Uuid
  view_kind       profile_view_kind @default(discovery)
  view_count      Int           @default(1)
  last_viewed_at  DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  total_seconds   Int           @default(0)
  created_at      DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  viewer_org      organizations @relation("discovery_views_given", fields: [viewer_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  target_org      organizations @relation("discovery_views_received", fields: [target_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([viewer_org_id, target_org_id, view_kind], map: "discovery_profile_views_unique")
  @@index([target_org_id, last_viewed_at(sort: Desc)], map: "discovery_views_target_idx")
  @@index([viewer_org_id, last_viewed_at(sort: Desc)], map: "discovery_views_viewer_idx")
  @@schema("public")
}

/// Computed AI match score between two orgs (recalculated nightly / on profile change).
model ai_match_scores {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_org_id       String        @db.Uuid
  to_org_id         String        @db.Uuid
  overall_score     Int           @db.SmallInt  // 0-100
  score_breakdown   Json          @default("{}")
  // {industry, stage, check_size, geography, business_model, traction, team_fit, value_add}
  match_reasons     String[]      @default([])
  disqualified      Boolean       @default(false)
  disqualify_reason String?
  calculated_at     DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  from_org          organizations @relation("ai_match_from", fields: [from_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  to_org            organizations @relation("ai_match_to", fields: [to_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([from_org_id, to_org_id], map: "ai_match_scores_unique")
  @@index([from_org_id, overall_score(sort: Desc)], map: "ai_match_scores_from_score_idx")
  @@index([to_org_id, overall_score(sort: Desc)], map: "ai_match_scores_to_score_idx")
  @@schema("public")
}

/// User's feedback on a match (for the learning algorithm).
model ai_match_feedback {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_org_id     String              @db.Uuid
  target_org_id   String              @db.Uuid
  feedback_type   match_feedback_type
  decline_reason  String?
  created_at      DateTime            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  from_org        organizations       @relation("ai_match_feedback_from", fields: [from_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([from_org_id, target_org_id], map: "ai_match_feedback_unique")
  @@index([from_org_id, created_at(sort: Desc)], map: "ai_match_feedback_from_idx")
  @@schema("public")
}

/// Stored embeddings for an org profile (pgvector-ready).
/// embedding_vector is JSON until pgvector migration is applied.
model org_ai_embeddings {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id           String        @db.Uuid
  embedding_text   String
  embedding_vector Json          @default("[]") // later: vector(1536)
  embedding_model  String        @default("text-embedding-3-large")
  created_at       DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  org              organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([org_id], map: "org_ai_embeddings_org_unique")
  @@index([updated_at(sort: Desc)], map: "org_ai_embeddings_updated_idx")
  @@schema("public")
}

/// Async job queue for computing embeddings + match scores.
model ai_embedding_jobs {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id      String        @db.Uuid
  status      String        @default("pending") // pending | running | succeeded | failed
  attempts    Int           @default(0)
  last_error  String?
  run_after   DateTime?     @db.Timestamptz(6)
  started_at  DateTime?     @db.Timestamptz(6)
  finished_at DateTime?     @db.Timestamptz(6)
  created_at  DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at  DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  org         organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status, run_after], map: "ai_embedding_jobs_status_run_after_idx")
  @@index([org_id, created_at(sort: Desc)], map: "ai_embedding_jobs_org_created_idx")
  @@schema("public")
}

/// Warm introduction request (startup or advisor requests platform to intro them to an investor).
model warm_intro_requests {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_org_id    String        @db.Uuid    // who is requesting the intro
  receiver_org_id  String        @db.Uuid    // who they want to be introduced to
  via_advisor_org_id String?     @db.Uuid    // optional: advisor co-signing the intro
  message          String?
  status           String        @default("pending")
  // pending | accepted | declined | expired
  response_note    String?
  created_at       DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  responded_at     DateTime?     @db.Timestamptz(6)
  expires_at       DateTime?     @db.Timestamptz(6)
  sender_org       organizations @relation("warm_intro_sender", fields: [sender_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  receiver_org     organizations @relation("warm_intro_receiver", fields: [receiver_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  via_advisor_org  organizations? @relation("warm_intro_via_advisor", fields: [via_advisor_org_id], references: [id], onUpdate: NoAction)

  @@index([sender_org_id, status], map: "warm_intro_sender_status_idx")
  @@index([receiver_org_id, status, created_at(sort: Desc)], map: "warm_intro_receiver_status_idx")
  @@schema("public")
}

// =============================================================================
// §7 — CONNECTIONS & MESSAGING
// =============================================================================

model connection_requests {
  id           String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  from_org_id  String                    @db.Uuid
  to_org_id    String                    @db.Uuid
  status       connection_request_status @default(pending)
  message      String?
  created_at   DateTime                  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  responded_at DateTime?                 @db.Timestamptz(6)
  from_org     organizations             @relation("connection_requests_from_org", fields: [from_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  to_org       organizations             @relation("connection_requests_to_org", fields: [to_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([from_org_id, to_org_id], map: "connection_requests_from_to_unique")
  @@index([to_org_id, status], map: "connection_requests_to_status_idx")
  @@index([from_org_id, status], map: "connection_requests_from_status_idx")
  @@schema("public")
}

model connections {
  id         String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_a_id   String                @db.Uuid
  org_b_id   String                @db.Uuid
  created_at DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  org_a      organizations         @relation("connections_org_a", fields: [org_a_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  org_b      organizations         @relation("connections_org_b", fields: [org_b_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages   connection_messages[]
  deal_room  deal_rooms?

  @@unique([org_a_id, org_b_id], map: "connections_orgs_unique")
  @@index([org_a_id], map: "connections_org_a_idx")
  @@index([org_b_id], map: "connections_org_b_idx")
  @@schema("public")
}

model connection_messages {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connection_id String        @db.Uuid
  from_org_id   String        @db.Uuid
  body          String
  created_at    DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  connection    connections   @relation(fields: [connection_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  from_org      organizations @relation(fields: [from_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([connection_id, created_at(sort: Asc)], map: "connection_messages_connection_created_idx")
  @@schema("public")
}

// =============================================================================
// §8 — DEAL ROOM  (negotiation workspace)
// =============================================================================

/// Deal discussion request created when an investor starts a deal discussion with a startup.
model deal_room_requests {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id String   @db.Uuid
  investor_org_id String  @db.Uuid
  initiated_by   String?  @db.Uuid
  status         String   @default("pending")
  message        String?
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  responded_at   DateTime? @db.Timestamptz(6)
  startup_org    organizations @relation("deal_room_requests_startup", fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  investor_org   organizations @relation("deal_room_requests_investor", fields: [investor_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([startup_org_id, investor_org_id], map: "deal_room_requests_unique_pair")
  @@index([startup_org_id, status, created_at(sort: Desc)], map: "deal_room_requests_startup_status_idx")
  @@index([investor_org_id, status, created_at(sort: Desc)], map: "deal_room_requests_investor_status_idx")
  @@schema("public")
}

/// Deal Room: created when a startup and investor accept a connection.
/// Also supports advisor participation (syndicate later).
model deal_rooms {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connection_id   String            @unique @db.Uuid
  name            String?
  stage           deal_room_stage   @default(interest)
  description     String?
  target_amount   BigInt?           // total capital sought (for syndicate tracking)
  committed_total BigInt?           @default(0)
  terms_accepted  Boolean           @default(false)
  closed_at       DateTime?         @db.Timestamptz(6)
  created_at      DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  connection      connections       @relation(fields: [connection_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  participants    deal_room_participants[]
  messages        deal_room_messages[]
  stage_history   deal_room_stage_history[]
  commitments     deal_room_commitments[]
  milestones      deal_room_milestones[]
  agreements      deal_room_agreements[]
  data_room_links deal_room_data_room_links[]

  @@schema("public")
}

/// Who participates in a deal room and in which role.
model deal_room_participants {
  id            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id  String                    @db.Uuid
  org_id        String                    @db.Uuid
  role          deal_room_participant_role
  invited_at    DateTime                  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  accepted_at   DateTime?                 @db.Timestamptz(6)
  left_at       DateTime?                 @db.Timestamptz(6)
  deal_room     deal_rooms                @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations organizations             @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([deal_room_id, org_id], map: "deal_room_participants_unique")
  @@index([deal_room_id, role], map: "deal_room_participants_room_role_idx")
  @@schema("public")
}

/// Chat messages inside the deal room.
model deal_room_messages {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id String      @db.Uuid
  sender_user_id String    @db.Uuid
  body         String
  attachment_url String?
  attachment_name String?
  is_ai_summary  Boolean   @default(false)
  created_at   DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  deal_room    deal_rooms  @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender       users       @relation(fields: [sender_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deal_room_id, created_at(sort: Asc)], map: "deal_room_messages_room_created_idx")
  @@schema("public")
}

/// Audit trail of deal stage changes.
model deal_room_stage_history {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id String          @db.Uuid
  from_stage   deal_room_stage?
  to_stage     deal_room_stage
  changed_by   String?         @db.Uuid
  note         String?
  created_at   DateTime        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  deal_room    deal_rooms      @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deal_room_id, created_at(sort: Desc)], map: "deal_room_stage_history_idx")
  @@schema("public")
}

/// Investor commitment records (amount + conditions).
model deal_room_commitments {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id    String        @db.Uuid
  investor_org_id String        @db.Uuid
  amount_usd      BigInt
  conditions      String?
  notes           String?
  status          String        @default("soft")
  // soft | confirmed | withdrawn
  committed_at    DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  deal_room       deal_rooms    @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deal_room_id, status], map: "deal_room_commitments_room_status_idx")
  @@schema("public")
}

/// Milestone tracker inside the deal room (AI can assist).
model deal_room_milestones {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id String      @db.Uuid
  title        String
  description  String?
  due_date     DateTime?   @db.Date
  completed_at DateTime?   @db.Timestamptz(6)
  sort_order   Int         @default(0)
  created_at   DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  deal_room    deal_rooms  @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deal_room_id, sort_order], map: "deal_room_milestones_room_order_idx")
  @@schema("public")
}

/// Deal agreements / term sheets (standard template or custom).
model deal_room_agreements {
  id           String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id String                       @db.Uuid
  title        String
  template_key String?                      // standard_term_sheet | nda | mou | custom
  content_text String?                      // rendered agreement body
  file_url     String?                      // optional: uploaded signed PDF
  status       deal_room_agreement_status   @default(draft)
  signed_by    Json                         @default("[]")  // [{org_id, signed_at}]
  created_at   DateTime                     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at   DateTime                     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  deal_room    deal_rooms                   @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([deal_room_id, status], map: "deal_room_agreements_room_status_idx")
  @@schema("public")
}

/// Links a deal room to a startup's data room (for due diligence access).
model deal_room_data_room_links {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_room_id      String      @db.Uuid
  startup_org_id    String      @db.Uuid
  terms_accepted_at DateTime?   @db.Timestamptz(6)
  created_at        DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  deal_room         deal_rooms  @relation(fields: [deal_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([deal_room_id, startup_org_id], map: "deal_room_data_room_links_unique")
  @@schema("public")
}

// =============================================================================
// §9 — DATA ROOM  (document vault + access control + analytics)
// =============================================================================

/// Logical folders within a startup's data room (replaces flat folder_path string).
model startup_data_room_folders {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id String        @db.Uuid
  name           String
  parent_id      String?       @db.Uuid  // null = root folder
  sort_order     Int           @default(0)
  created_at     DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations  organizations @relation(fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parent         startup_data_room_folders?  @relation("folder_children", fields: [parent_id], references: [id], onUpdate: NoAction)
  children       startup_data_room_folders[] @relation("folder_children")
  documents      startup_data_room_documents[]

  @@index([startup_org_id, parent_id], map: "startup_dr_folders_org_parent_idx")
  @@schema("public")
}

/// Documents stored in a startup's data room.
model startup_data_room_documents {
  id                  String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id      String                          @db.Uuid
  folder_id           String?                         @db.Uuid
  folder_path         String?                         // legacy flat path (kept for backward compat)
  document_type       startup_data_room_document_type
  title               String
  file_url            String?
  storage_bucket      String?
  storage_object_path String?
  file_name           String?
  file_size_bytes     BigInt?
  content_type        String?
  summary             String?
  is_confidential     Boolean                         @default(true)
  watermark_enabled   Boolean                         @default(true)
  download_enabled    Boolean                         @default(false)
  uploaded_by         String?                         @db.Uuid
  created_at          DateTime                        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at          DateTime                        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations       organizations                   @relation(fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users?                          @relation(fields: [uploaded_by], references: [id], onUpdate: NoAction)
  folder              startup_data_room_folders?      @relation(fields: [folder_id], references: [id], onUpdate: NoAction)
  document_views      data_room_document_views[]

  @@unique([startup_org_id, document_type], map: "startup_data_room_documents_org_type_unique")
  @@index([startup_org_id, updated_at(sort: Desc)], map: "startup_data_room_documents_org_updated_idx")
  @@index([storage_bucket, storage_object_path], map: "startup_data_room_documents_storage_idx", where: raw("((storage_bucket IS NOT NULL) AND (storage_object_path IS NOT NULL))"))
  @@schema("public")
}

/// Audit log of every data room action (upload, delete, folder create, view, etc.).
model startup_data_room_audit_logs {
  id                  String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id      String                          @db.Uuid
  action              String                          // folder_created | document_upserted | document_deleted | access_granted | access_revoked | terms_accepted
  folder_path         String?
  document_id         String?                         @db.Uuid
  document_type       startup_data_room_document_type?
  title               String?
  file_url            String?
  storage_bucket      String?
  storage_object_path String?
  file_name           String?
  file_size_bytes     BigInt?
  content_type        String?
  summary             String?
  actor_user_id       String?                         @db.Uuid
  metadata            Json                            @default("{}")
  created_at          DateTime                        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations       organizations                   @relation(fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users?                          @relation(fields: [actor_user_id], references: [id], onUpdate: NoAction)

  @@index([startup_org_id, created_at(sort: Desc)], map: "startup_data_room_audit_logs_org_created_idx")
  @@index([startup_org_id, folder_path], map: "startup_data_room_audit_logs_org_folder_idx")
  @@schema("public")
}

/// Investor/advisor requests access to a startup's data room.
model data_room_access_requests {
  id              String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id  String                    @db.Uuid
  requester_org_id String                   @db.Uuid
  message         String?
  status          data_room_access_status   @default(pending)
  reviewed_at     DateTime?                 @db.Timestamptz(6)
  review_note     String?
  created_at      DateTime                  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  startup_org     organizations             @relation("dr_access_owner", fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  requester_org   organizations             @relation("dr_access_requester", fields: [requester_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([startup_org_id, requester_org_id], map: "data_room_access_requests_unique")
  @@index([startup_org_id, status], map: "data_room_access_requests_startup_status_idx")
  @@schema("public")
}

/// Approved data room access record.
model data_room_access_grants {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id    String                  @db.Uuid
  grantee_org_id    String                  @db.Uuid
  permission_level  data_room_permission_level @default(view)
  terms_accepted_at DateTime?               @db.Timestamptz(6)
  granted_at        DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  revoked_at        DateTime?               @db.Timestamptz(6)
  expires_at        DateTime?               @db.Timestamptz(6)
  organizations     organizations           @relation(fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([startup_org_id, grantee_org_id], map: "data_room_access_grants_unique")
  @@index([grantee_org_id, revoked_at], map: "data_room_access_grants_grantee_idx")
  @@schema("public")
}

/// Recorded Data Room consent (ToS) by a granted org.
model data_room_consents {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startup_org_id String   @db.Uuid
  grantee_org_id String   @db.Uuid
  consented_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  ip_address     String?
  user_agent     String?
  created_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  startup_org organizations @relation("dr_consent_startup", fields: [startup_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  grantee_org organizations @relation("dr_consent_grantee", fields: [grantee_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([startup_org_id, grantee_org_id], map: "data_room_consents_unique_pair")
  @@index([startup_org_id, consented_at(sort: Desc)], map: "data_room_consents_startup_idx")
  @@index([grantee_org_id, consented_at(sort: Desc)], map: "data_room_consents_grantee_idx")
  @@schema("public")
}

/// Document-level view analytics (who viewed what, when, how long).
model data_room_document_views {
  id              String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  document_id     String                       @db.Uuid
  viewer_org_id   String                       @db.Uuid
  view_count      Int                          @default(1)
  total_seconds   Int                          @default(0)
  last_viewed_at  DateTime                     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at      DateTime                     @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  document        startup_data_room_documents  @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  viewer_org      organizations                @relation(fields: [viewer_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([document_id, viewer_org_id], map: "data_room_document_views_unique")
  @@index([document_id, last_viewed_at(sort: Desc)], map: "data_room_document_views_doc_idx")
  @@schema("public")
}

// =============================================================================
// §10 — SYNDICATES  (co-investor groups, Elite only)
// =============================================================================

/// A syndicate led by an investor to pool capital for a single startup deal.
model syndicates {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_org_id     String            @db.Uuid
  startup_org_id  String?           @db.Uuid  // target startup (if deal-specific)
  name            String
  description     String?
  target_amount   BigInt?
  minimum_check   BigInt?
  status          syndicate_status  @default(forming)
  visibility      String            @default("private")
  // private | platform | public
  closed_at       DateTime?         @db.Timestamptz(6)
  created_at      DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  lead_org        organizations     @relation(fields: [lead_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  members         syndicate_members[]
  invites         syndicate_invites[]

  @@index([lead_org_id, status], map: "syndicates_lead_status_idx")
  @@index([startup_org_id], map: "syndicates_startup_idx")
  @@schema("public")
}

/// Members of a syndicate.
model syndicate_members {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syndicate_id  String                  @db.Uuid
  org_id        String                  @db.Uuid
  committed_usd BigInt?
  status        syndicate_member_status @default(invited)
  joined_at     DateTime?               @db.Timestamptz(6)
  created_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  syndicate     syndicates              @relation(fields: [syndicate_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations organizations           @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([syndicate_id, org_id], map: "syndicate_members_unique")
  @@index([org_id, status], map: "syndicate_members_org_status_idx")
  @@schema("public")
}

/// Pending invitations to join a syndicate.
model syndicate_invites {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  syndicate_id  String      @db.Uuid
  invitee_org_id String     @db.Uuid
  message       String?
  status        String      @default("pending")
  // pending | accepted | declined | expired
  expires_at    DateTime?   @db.Timestamptz(6)
  created_at    DateTime    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  responded_at  DateTime?   @db.Timestamptz(6)
  syndicate     syndicates  @relation(fields: [syndicate_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([syndicate_id, invitee_org_id], map: "syndicate_invites_unique")
  @@index([invitee_org_id, status], map: "syndicate_invites_invitee_idx")
  @@schema("public")
}

// =============================================================================
// §11 — PAYMENTS & FEES
// =============================================================================

/// All payment transactions (subscription, success fees, escrow releases, etc.).
model payment_transactions {
  id                  String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id              String                      @db.Uuid
  transaction_type    String                      // subscription | success_fee | escrow_release | refund | other
  amount_cents        BigInt
  currency            String                      @default("USD")
  status              payment_transaction_status  @default(pending)
  provider            String                      @default("stripe")
  provider_payment_id String?                     // Stripe payment intent ID
  provider_invoice_id String?
  description         String?
  metadata            Json                        @default("{}")
  failed_reason       String?
  created_at          DateTime                    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at          DateTime                    @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations       organizations               @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([org_id, created_at(sort: Desc)], map: "payment_transactions_org_created_idx")
  @@index([provider, provider_payment_id], map: "payment_transactions_provider_id_idx")
  @@schema("public")
}

/// Tracks success fees owed when a deal closes (due 12 months from intro date).
model success_fee_records {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payer_org_id        String        @db.Uuid    // who owes the fee (startup or consultant)
  deal_room_id        String?       @db.Uuid
  intro_date          DateTime      @db.Date
  fee_trigger         String        // capital_raised | consulting_contract
  gross_amount_usd    BigInt        // deal/capital amount
  fee_rate_pct_x100   Int           // rate * 100 (e.g. 350 = 3.5%)
  fee_amount_usd      BigInt
  status              String        @default("pending")
  // pending | invoiced | paid | waived | disputed
  due_date            DateTime?     @db.Date
  paid_at             DateTime?     @db.Timestamptz(6)
  notes               String?
  metadata            Json          @default("{}")
  created_at          DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at          DateTime      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations       organizations @relation(fields: [payer_org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([payer_org_id, status], map: "success_fee_records_payer_status_idx")
  @@schema("public")
}

// =============================================================================
// §12 — NOTIFICATIONS
// =============================================================================

/// In-app notifications (connection requests, acceptances, deal room, etc.).
model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  type       String    // connection_request | connection_accepted | deal_room_created | deal_room_message | data_room_access_request | data_room_access_granted | milestone_completed | new_match | payment_received | etc.
  title      String
  body       String?
  link       String?
  action_id  String?   // reference ID for quick action (e.g. connection_request id)
  read_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, read_at], map: "notifications_user_read_idx")
  @@index([user_id, created_at(sort: Desc)], map: "notifications_user_created_idx")
  @@schema("public")
}

// =============================================================================
// §13 — SECURITY  (2FA, device tracking, audit events)
// =============================================================================

/// Two-factor authentication settings per user.
model user_two_factor_settings {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String                  @db.Uuid
  method        user_two_factor_method
  is_enabled    Boolean                 @default(false)
  secret_hash   String?                 // TOTP secret (hashed/encrypted)
  phone_number  String?                 // for SMS
  backup_codes  String[]                @default([])
  // hashed backup codes
  verified_at   DateTime?               @db.Timestamptz(6)
  created_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users         users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, method], map: "user_two_factor_settings_unique")
  @@schema("public")
}

/// Log of security-relevant events per user.
model user_security_events {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String              @db.Uuid
  event_type  security_event_type
  ip_address  String?
  user_agent  String?
  country     String?
  city        String?
  device_id   String?             @db.Uuid
  metadata    Json                @default("{}")
  created_at  DateTime            @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users       users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "user_security_events_user_created_idx")
  @@schema("public")
}

/// Known devices for a user (used to show "active sessions" in security settings).
model user_devices {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  device_name   String?
  device_type   String?   // mobile | tablet | desktop | other
  user_agent    String?
  ip_address    String?
  country       String?
  is_trusted    Boolean   @default(false)
  last_seen_at  DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at    DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  revoked_at    DateTime? @db.Timestamptz(6)
  users         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, last_seen_at(sort: Desc)], map: "user_devices_user_idx")
  @@schema("public")
}

// =============================================================================
// §14 — SUPPORT  (help desk + AI bot)
// =============================================================================

/// Help & Support tickets. AI bot handles first; escalates to human support.
model support_tickets {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id          String?                 @db.Uuid
  user_id         String                  @db.Uuid
  subject         String
  category        String?                 // billing | account | data_room | deal_room | matching | other
  status          support_ticket_status   @default(open)
  priority        support_ticket_priority @default(medium)
  assigned_to     String?                 // admin user id
  ai_resolved     Boolean                 @default(false)
  resolution_note String?
  created_at      DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at      DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  resolved_at     DateTime?               @db.Timestamptz(6)
  users           users                   @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations   organizations?          @relation(fields: [org_id], references: [id], onUpdate: NoAction)
  messages        support_messages[]

  @@index([status, priority, created_at(sort: Desc)], map: "support_tickets_status_priority_idx")
  @@index([user_id, status], map: "support_tickets_user_status_idx")
  @@schema("public")
}

/// Messages in a support ticket thread.
model support_messages {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id   String          @db.Uuid
  sender_id   String          @db.Uuid
  is_staff    Boolean         @default(false)
  is_ai       Boolean         @default(false)
  body        String
  created_at  DateTime        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  ticket      support_tickets @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users           @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ticket_id, created_at(sort: Asc)], map: "support_messages_ticket_created_idx")
  @@schema("public")
}

/// AI chatbot session (help & support widget conversations).
model ai_chat_sessions {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  context        String?   // help | deal_room | data_room | matching
  messages       Json      @default("[]")  // [{role: user|assistant, content, created_at}]
  escalated      Boolean   @default(false)
  escalated_at   DateTime? @db.Timestamptz(6)
  ticket_id      String?   @db.Uuid
  created_at     DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at     DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "ai_chat_sessions_user_created_idx")
  @@schema("public")
}

/// Per-user notification channel preferences and type overrides.
model user_notification_preferences {
  user_id          String   @id @db.Uuid
  in_app_enabled   Boolean  @default(true)
  email_enabled    Boolean  @default(true)
  telegram_enabled Boolean  @default(false)
  telegram_chat_id String?
  type_overrides   Json     @default("{}") // { [type]: { in_app?: boolean, email?: boolean, telegram?: boolean } }
  created_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at       DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users            users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

