// =============================================================================
// IMPACTIS PLATFORM — MASTER PRISMA SCHEMA
// =============================================================================
// Tech: NestJS (server) + Next.js (client) | Auth: Better Auth | Storage: Cloudflare R2
// Payment: Stripe | DB: PostgreSQL | Cache: Upstash Redis
//
// ROLE OVERVIEW
//   startup   — company seeking funding / advisor support
//   investor  — individual/fund providing capital
//   advisor   — consultant/expert providing services
//
// TIER OVERVIEW (per segment)
//   free → pro → elite
//
// MODULE MAP
//   §1  Auth & Session          (Better Auth managed)
//   §2  Users & Profiles        (personal identity + scoring)
//   §3  Organizations           (entity per role)
//   §4  Onboarding              (role-specific questions, step tracking)
//   §5  Billing & Subscriptions (plans, prices, capabilities, usage)
//   §6  Discovery & AI Matching (scores, feedback, profile views)
//   §7  Connections             (requests, accepted, messages)
//   §8  Deal Room               (negotiation workspace, stages, chat)
//   §9  Data Room               (document vault, access control, analytics)
//   §10 Syndicates              (co-investor groups)
//   §11 Payments & Fees         (transactions, success fees, escrow)
//   §12 Notifications           (in-app + email triggers)
//   §13 Security                (2FA, devices, audit events)
//   §14 Support                 (tickets, AI chatbot, customer support)
//   §15 Admin                   (admin users, platform audit)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// =============================================================================
// §1 — AUTH & SESSION  (Better Auth managed tables, kept as-is)
// =============================================================================

model users {
  id             String    @id @db.Uuid
  name           String?
  email          String?
  emailVerified  Boolean?  @default(false) @map("email_verified")
  image          String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  raw_user_meta_data Json? @map("raw_user_meta_data")

  // Relations
  accounts                                      accounts[]
  sessions                                      sessions[]
  profiles                                      profiles?
  advisor_profiles                              advisor_profiles[]
  investor_profiles                             investor_profiles[]
  startup_profiles                              startup_profiles[]
  startup_data_room_documents                   startup_data_room_documents[]
  startup_data_room_audit_logs                  startup_data_room_audit_logs[]
  startup_posts_startup_posts_created_byTousers startup_posts[] @relation("startup_posts_created_byTousers")
  startup_posts_startup_posts_updated_byTousers startup_posts[] @relation("startup_posts_updated_byTousers")
  org_invites_org_invites_accepted_byTousers    org_invites[]   @relation("org_invites_accepted_byTousers")
  org_invites_org_invites_invited_byTousers     org_invites[]   @relation("org_invites_invited_byTousers")
  org_members_org_members_invited_byTousers     org_members[]   @relation("org_members_invited_byTousers")
  org_members_org_members_user_idTousers        org_members?    @relation("org_members_user_idTousers")
  org_status                                    org_status[]
  org_verifications                             org_verifications[]
  notifications                                 notifications[]
  two_factor_settings                           user_two_factor_settings[]
  security_events                               user_security_events[]
  user_devices                                  user_devices[]
  support_tickets                               support_tickets[]
  support_messages                              support_messages[]
  ai_chat_sessions                              ai_chat_sessions[]
  deal_room_messages                            deal_room_messages[]
  admin_users                                   admin_users[]
  user_notification_preferences                  user_notification_preferences?

  @@schema("public")
}

model accounts {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamptz(6)
  refreshTokenExpiresAt DateTime? @db.Timestamptz(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @db.Timestamptz(6)
  users                 users     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "public.accounts_userId_idx")
  @@schema("public")
}

model sessions {
  id        String   @id
  expiresAt DateTime @db.Timestamptz(6)
  token     String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "public.sessions_userId_idx")
  @@schema("public")
}

model jwks {
  id         String    @id
  publicKey  String
  privateKey String
  createdAt  DateTime  @db.Timestamptz(6)
  expiresAt  DateTime? @db.Timestamptz(6)

  @@schema("public")
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([identifier])
  @@schema("public")
}

// =============================================================================
// §2 — USERS & PROFILES  (personal identity, completeness scoring)
// =============================================================================

/// Personal profile linked 1:1 to a user. Covers name, photo, bio, links.
model profiles {
  id                         String    @id @db.Uuid
  full_name                  String?
  location                   String?
  bio                        String?
  avatar_url                 String?
  phone                      String?
  headline                   String?
  website_url                String?
  linkedin_url               String?
  twitter_url                String?
  crunchbase_url             String?
  angellist_url              String?
  timezone_name              String?
  preferred_contact_method   String?
  profile_completeness_percent Int?   @db.SmallInt
  created_at                 DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime? @default(now()) @db.Timestamptz(6)
  users                      users     @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

// =============================================================================
// §3 — ORGANIZATIONS  (one org per user; type = startup | investor | advisor)
// =============================================================================

/// One organization per user. The type determines which role-specific tables apply.
model organizations {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type                        org_type
  name                        String
  location                    String?
  country                     String?
  industry_tags               String[]                      @default([])
  logo_url                    String?
  website_url                 String?
  finance_status              String?
  onboarding_complete         Boolean                       @default(false)
  created_at                  DateTime                      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                  DateTime                      @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)

  // Role-specific profiles
  advisor_profiles            advisor_profiles?
  investor_profiles           investor_profiles?
  startup_profiles            startup_profiles?
  startup_posts               startup_posts?
  startup_data_room_documents startup_data_room_documents[]
  startup_data_room_audit_logs startup_data_room_audit_logs[]
  startup_data_room_folders   startup_data_room_folders[]

  // Org management
  org_capabilities_overrides  org_capabilities_overrides[]
  org_feature_usage_counters  org_feature_usage_counters[]
  org_invites                 org_invites[]
  org_members                 org_members[]
  org_status                  org_status?
  org_subscription_accounts   org_subscription_accounts?
  org_subscriptions           org_subscriptions[]
  org_verifications           org_verifications?

  // Onboarding
  onboarding_progress         onboarding_progress[]
  investor_onboarding_answers investor_onboarding_answers?
  startup_onboarding_answers  startup_onboarding_answers?
  advisor_onboarding_answers  advisor_onboarding_answers?
  org_profile_scores          org_profile_scores?

  // Discovery / Matching
  discovery_views_given       discovery_profile_views[]     @relation("discovery_views_given")
  discovery_views_received    discovery_profile_views[]     @relation("discovery_views_received")
  ai_match_scores_from        ai_match_scores[]             @relation("ai_match_from")
  ai_match_scores_to          ai_match_scores[]             @relation("ai_match_to")
  ai_match_feedback_from      ai_match_feedback[]           @relation("ai_match_feedback_from")
  org_ai_embeddings           org_ai_embeddings?
  ai_embedding_jobs           ai_embedding_jobs[]
  warm_intros_sent            warm_intro_requests[]         @relation("warm_intro_sender")
  warm_intros_received        warm_intro_requests[]         @relation("warm_intro_receiver")
  warm_intros_via             warm_intro_requests[]         @relation("warm_intro_via_advisor")

  // Connections
  connection_requests_from    connection_requests[]         @relation("connection_requests_from_org")
  connection_requests_to      connection_requests[]         @relation("connection_requests_to_org")
  connections_org_a           connections[]                 @relation("connections_org_a")
  connections_org_b           connections[]                 @relation("connections_org_b")
  connection_messages         connection_messages[]

  // Deal Rooms
  deal_room_participants      deal_room_participants[]
  deal_room_requests_as_startup deal_room_requests[]        @relation("deal_room_requests_startup")
  deal_room_requests_as_investor deal_room_requests[]       @relation("deal_room_requests_investor")

  // Data Room access
  data_room_access_requests_requester data_room_access_requests[] @relation("dr_access_requester")
  data_room_access_requests_owner     data_room_access_requests[] @relation("dr_access_owner")
  data_room_access_grants             data_room_access_grants[]
  data_room_document_views            data_room_document_views[]
  data_room_consents_as_startup       data_room_consents[]   @relation("dr_consent_startup")
  data_room_consents_as_grantee       data_room_consents[]   @relation("dr_consent_grantee")

  // Syndicates
  syndicates_lead             syndicates[]
  syndicate_members           syndicate_members[]

  // Payments
  payment_transactions        payment_transactions[]
  success_fee_records         success_fee_records[]

  // Support tickets
  support_tickets             support_tickets[]

  @@index([type, created_at(sort: Desc)], map: "organizations_type_created_idx")
  @@schema("public")
}

model org_members {
  org_id                              String                @db.Uuid
  user_id                             String                @unique(map: "org_members_single_org_per_user_idx") @db.Uuid
  member_role                         org_member_role       @default(member)
  status                              org_membership_status @default(active)
  invited_by                          String?               @db.Uuid
  joined_at                           DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  created_at                          DateTime              @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users_org_members_invited_byTousers users?                @relation("org_members_invited_byTousers", fields: [invited_by], references: [id], onUpdate: NoAction)
  organizations                       organizations         @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_org_members_user_idTousers    users                 @relation("org_members_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([org_id, user_id])
  @@index([org_id, status], map: "org_members_org_status_idx")
  @@index([user_id, status, created_at], map: "org_members_user_status_created_idx")
  @@index([user_id, status, created_at, org_id], map: "org_members_user_status_created_org_idx")
  @@schema("public")
}

model org_invites {
  id                                   String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id                               String            @db.Uuid
  invited_email                        String
  member_role                          org_member_role   @default(member)
  status                               org_invite_status @default(pending)
  invited_by                           String            @db.Uuid
  accepted_by                          String?           @db.Uuid
  token_hash                           String            @unique
  expires_at                           DateTime          @db.Timestamptz(6)
  notes                                String?
  created_at                           DateTime          @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  responded_at                         DateTime?         @db.Timestamptz(6)
  users_org_invites_accepted_byTousers users?            @relation("org_invites_accepted_byTousers", fields: [accepted_by], references: [id], onUpdate: NoAction)
  users_org_invites_invited_byTousers  users             @relation("org_invites_invited_byTousers", fields: [invited_by], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organizations                        organizations     @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([org_id, status, created_at(sort: Desc)], map: "org_invites_org_status_created_idx")
  @@schema("public")
}

model org_status {
  org_id        String               @id @db.Uuid
  status        org_lifecycle_status @default(active)
  updated_by    String?              @db.Uuid
  reason        String?
  created_at    DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime             @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations organizations        @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users?               @relation(fields: [updated_by], references: [id], onUpdate: NoAction)

  @@schema("public")
}

model org_verifications {
  org_id        String                  @id @db.Uuid
  status        org_verification_status @default(unverified)
  reviewed_by   String?                 @db.Uuid
  reviewed_at   DateTime?               @db.Timestamptz(6)
  notes         String?
  documents     Json                    @default("[]")
  created_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations organizations           @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users?                  @relation(fields: [reviewed_by], references: [id], onUpdate: NoAction)

  @@schema("public")
}

// =============================================================================
// §4 — ONBOARDING  (step tracking + role-specific detailed answers)
// =============================================================================

/// Tracks which onboarding steps have been completed/skipped for an org.
/// step_key examples: basic_info | investment_criteria | industry_focus | pitch_materials | verification
model onboarding_progress {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id        String                  @db.Uuid
  step_key      String
  step_number   Int
  status        onboarding_step_status  @default(not_started)
  skipped_at    DateTime?               @db.Timestamptz(6)
  completed_at  DateTime?               @db.Timestamptz(6)
  created_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at    DateTime                @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations organizations           @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([org_id, step_key], map: "onboarding_progress_org_step_key_unique")
  @@index([org_id, step_number], map: "onboarding_progress_org_step_idx")
  @@schema("public")
}

/// Full investor onboarding answers (mirrors the PDF template).
model investor_onboarding_answers {
  org_id String @id @db.Uuid

  // §1 Basic / Identity
  profile_type                String?    // angel_individual | angel_group | vc_fund | corporate_vc | family_office | private_equity | strategic | accelerator
  entity_name                 String?
  primary_contact_name        String?
  title_role                  String?
  linkedin_url                String?
  crunchbase_url              String?
  angellist_url               String?
  twitter_url                 String?

  // §2 Investment Experience
  investing_years_band        String?    // <1 | 1-3 | 3-5 | 5-10 | 10+
  total_investments_made_band String?    // 0 | 1-5 | 6-15 | 16-30 | 31-50 | 50+
  notable_exits               String?

  // §3 Investment Capacity
  check_size_band             String?    // e.g. 25k-50k | 50k-100k | etc.
  check_size_min_usd          BigInt?
  check_size_max_usd          BigInt?
  total_investable_capital_band String?
  new_investments_12mo_band   String?
  investment_structures       String[]   @default([])
  // equity_common | safe | convertible_note | etc.

  // §4 Stage Preference  (jsonb: [{stage, interest_level, portfolio_pct}])
  stage_preferences           Json       @default("[]")
  startup_maturity_preference String[]   @default([])

  // §5 Industry Focus  (jsonb: [{industry, rank, attitude: must_have|open_to|not_interested}])
  industry_preferences        Json       @default("[]")
  industry_expertise_summary  String?

  // §6 Geographic Preferences
  geographic_regions          String[]   @default([])
  specific_cities             String?
  remote_team_openness        String?

  // §7 Business Model Preference
  business_model_preferences  String[]   @default([])
  revenue_requirement_band    String?

  // §8 Investment Philosophy
  investment_approach         String?    // hands_on | strategic | passive | lead | follow_on
  value_add_offerings         String[]   @default([])
  specific_expertise          String?
  notable_doors               String?

  // §9 Founder Preferences  (jsonb: [{characteristic, rank}])
  founder_preferences         Json       @default("[]")
  team_composition_preference String?
  diversity_priority          String?

  // §10 Deal Structure
  round_participation         String?
  due_diligence_timeframe     String?
  board_seat_expectation      String?
  follow_on_capacity          String?

  // §11 Matching Preferences
  discovery_preference        String?
  deal_flow_volume_preference String?
  pitch_format_preferences    String[]   @default([])
  must_haves                  String[]   @default([])
  deal_breakers               String[]   @default([])

  // §12 Consultant Engagement
  consultant_engagement       String?
  consultant_services_needed  String[]   @default([])
  consultant_budget_band      String?

  // §13 Platform Engagement
  activity_level              String?
  response_time_commitment    String?
  quarterly_investment_target String?
  profile_visibility          String?

  // §14 Investment Thesis
  investment_thesis_bio       String?

  // §15 AI Matching Weights (jsonb: [{factor, rank}])
  match_algorithm_weights     Json       @default("[]")
  notification_threshold      String?    // 95+ | 85+ | 75+ | 60+ | manual
  notification_frequency      String?    // realtime | daily | weekly | biweekly

  created_at                  DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                  DateTime   @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations               organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// Full startup onboarding answers (mirrors the PDF template).
model startup_onboarding_answers {
  org_id String @id @db.Uuid

  // §1 Company Identity
  legal_name                  String?
  trading_name                String?
  company_email               String?
  founded_date                DateTime?  @db.Date
  country_of_incorporation    String?
  primary_office_location     String?
  linkedin_company_url        String?
  crunchbase_url              String?
  angellist_url               String?
  twitter_url                 String?
  product_demo_link           String?
  app_store_link              String?
  play_store_link             String?

  // §2 Stage
  company_stage_band          String?    // ideation | pre_seed_building | pre_seed_mvp | seed | series_a | series_b | series_c_plus | bootstrapped
  product_status              String?    // idea | wireframes | mvp_dev | mvp_launched | public_beta | launched | established
  time_in_business_band       String?    // <6mo | 6mo-1yr | 1-2yr | 2-3yr | 3-5yr | 5yr+

  // §3 Business Overview
  problem_statement           String?
  target_customer_description String?
  current_alternatives        String?
  solution_statement          String?
  unique_advantage            String?
  elevator_pitch              String?

  // §4 Industry & Market
  primary_industry            String?
  sub_sector                  String?
  tam_band                    String?    // <100M | 100M-500M | 500M-1B | 1B-5B | 5B-20B | 20B+
  sam_band                    String?

  // §5 Business Model
  revenue_model               String?
  pricing_model_description   String?
  avg_monthly_price_usd       Int?
  avg_annual_price_usd        Int?
  target_customer_type        String?    // smb | mid_market | enterprise | consumer | mixed
  sales_motion                String?
  ltv_usd                     Int?
  cac_usd                     Int?

  // §6 Traction & Revenue
  current_revenue_status      String?
  mrr_usd                     Int?
  arr_usd                     Int?
  revenue_growth_rate_mom_pct Int?
  runway_months               Int?
  monthly_burn_usd            Int?
  gross_margin_pct            Int?
  cash_in_bank_usd            Int?
  profitability_status        String?    // profitable | break_even | not_profitable

  // §7 Customer Metrics
  total_paying_customers      Int?
  total_users                 Int?
  mau                         Int?
  waitlist_count              Int?
  churn_rate_pct              Int?
  nrr_pct                     Int?
  avg_customer_lifetime_months Int?
  key_traction_highlights     String?

  // §8 Team
  co_founders_count           Int?
  founders_data               Json       @default("[]")  // [{name, title, linkedin, background, expertise, education}]
  team_strengths              String?
  diversity_indicators        String[]   @default([])
  total_team_size             Int?
  team_breakdown              Json       @default("{}")
  // {engineering, product, sales, marketing, ops, other}
  key_hires_in_place          String[]   @default([])
  advisors_data               Json       @default("[]")  // [{name, background, value}]
  advisory_compensation       String?

  // §9 Funding History
  total_capital_raised_usd    BigInt?
  funding_rounds              Json       @default("[]")  // [{round, amount, date, lead_investor, valuation}]
  bootstrapped_status         String?
  notable_investors           String?

  // §10 Current Fundraise
  currently_fundraising       Boolean    @default(false)
  fundraising_timeline        String?
  round_type                  String?    // pre_seed | seed | series_a | series_b | other
  target_raise_usd            BigInt?
  minimum_raise_usd           BigInt?
  committed_so_far_usd        BigInt?
  round_structure             String?    // priced | safe | convertible_note | other
  use_of_funds                String?
  pre_money_valuation_usd     BigInt?
  post_money_valuation_usd    BigInt?
  valuation_cap_usd           BigInt?
  min_check_size_usd          Int?
  max_check_size_usd          Int?
  pro_rata_rights             Boolean?
  board_seat_allocation       String?
  target_close_date           DateTime?  @db.Date
  data_room_status            String?

  // §11 Investor Preferences
  ideal_investor_types        String[]   @default([])
  investor_involvement_pref   String?
  value_add_priorities        Json       @default("[]")  // [{value_type, rank}]
  specific_expertise_needed   String?
  geography_pref_for_investors String?
  investor_deal_breakers      String[]   @default([])

  // §12 Consultant Needs
  currently_seeking_consultants Boolean  @default(false)
  consultant_needs              Json      @default("[]")  // [{area, urgency, budget_available}]
  engagement_model_pref         String?
  consulting_budget_band        String?
  consulting_timeline           String?

  // §13 Matching Preferences
  discovery_preference          String?
  profile_visibility            String?
  match_algorithm_weights       Json      @default("[]")
  notification_threshold        String?
  smart_notification_triggers   String[]  @default([])

  // §14 Pitch Materials
  executive_summary_url         String?
  product_demo_video_url        String?
  video_pitch_url               String?
  one_pager_url                 String?

  // §15 IP & Technology
  ip_types                      String[]  @default([])
  tech_stack_summary            String?
  product_roadmap_highlights    String?

  created_at                    DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  updated_at                    DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  organizations                 organizations @relation(fields: [org_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

